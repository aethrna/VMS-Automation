{
  "manifest_version": 2,
  "name": "Lazy VMS",
  "version": "1.3",
  "permissions": ["https://vms.cyber2tower.com/*", "storage", "tabs"],
  "browser_specific_settings": { "gecko": { "id": "lazy-vms@reth.local" } },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Lazy VMS"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://vms.cyber2tower.com/Visitor/Access*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
